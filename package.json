{
  "name": "vocpage",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w frontend\" \"npm run dev -w backend\"",
    "prepare": "husky",
    "codegen": "openapi-typescript shared/openapi.yaml -o shared/types/api.ts"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.7.1",
    "@typescript-eslint/parser": "^7.7.1",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "eslint-plugin-n": "^17.2.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.2.5",
    "stylelint": "^16.3.1",
    "stylelint-declaration-strict-value": "^1.9.2"
  },
  "overrides": {
    "eslint": "^8.57.0"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{js,cjs,mjs}": [
      "prettier --write"
    ],
    "**/*.{json,md}": [
      "prettier --write"
    ],
    "**/*.{css,scss}": [
      "stylelint --fix",
      "prettier --write"
    ]
  }
}
