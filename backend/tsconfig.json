{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "..",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "types": ["node", "jest"]
  },
  "include": ["src", "../shared/contracts", "../shared/fixtures"],
  "exclude": ["node_modules", "dist", "**/__tests__/**", "**/*.test.ts"]
}
