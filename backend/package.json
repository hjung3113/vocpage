{
  "name": "@vocpage/backend",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest --runInBand",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "db:migrate": "node-pg-migrate up -m migrations",
    "db:migrate:down": "node-pg-migrate down -m migrations",
    "db:seed": "psql $DATABASE_URL -f seeds/dev_seed.sql",
    "db:seed:mock": "psql $DATABASE_URL -f seeds/mock-users.sql"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "express-session": "^1.18.0",
    "helmet": "^7.1.0",
    "js-yaml": "^4.1.0",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/jest": "^29.5.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.12.7",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.6",
    "jest": "^29.7.0",
    "pg-mem": "^3.0.14",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "tsx": "^4.21.0",
    "typescript": "^5.4.5"
  }
}
