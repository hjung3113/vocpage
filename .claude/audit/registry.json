    "design_tokens",
    "review_delegation",
    "decision_quality",
    "completion_protocol",
    "minimal_change",
    "docs_sync"
  ],
  "status_lifecycle": {
    "initial": "candidate",
    "terminal_suppressed": ["accepted_residual", "retired"],
    "stats_excluded": ["accepted_residual"],
    "transitions": {
      "candidate": ["promoted", "scoped", "retired", "detection_review"],
      "promoted": ["claude_md_queued", "hookify_queued", "spec_queued", "under_remediation"],
      "scoped": ["claude_md_queued", "hookify_queued", "spec_queued", "under_remediation"],
      "claude_md_queued": ["claude_md_added", "retired"],
      "claude_md_added": ["under_remediation"],
      "hookify_queued": ["hookified", "retired"],
      "hookified": ["under_remediation"],
      "spec_queued": ["spec_added", "retired"],
      "spec_added": ["under_remediation"],
      "under_remediation": ["remediated", "regressed", "remediation_inconclusive"],
      "remediated": ["regressed"],
      "regressed": [
        "under_remediation",
        "claude_md_queued",
        "hookify_queued",
        "spec_queued",
        "accepted_residual"
      ],
      "remediation_inconclusive": ["under_remediation", "accepted_residual"],
      "accepted_residual": [],
      "retired": ["regressed"],
      "detection_review": ["candidate", "retired"]
    }
  },
  "promotion_rules": {
    "promoted": {
      "min_sessions": 5,
      "min_lifetime_confidence": 0.4,
      "min_work_types": 2
    },
    "scoped": {
      "min_sessions": 5,
      "min_lifetime_confidence": 0.7,
      "min_work_types": 1
    },
    "remediated": {
      "min_post_fix_sessions": 5,
      "max_post_fix_confidence": 0.1,
      "min_post_fix_work_type_matches": 3
    },
    "remediation_inconclusive": {
      "trigger_when": "post_fix_sessions>=5 AND post_fix_work_type_matches<3"
    },
    "regressed": {
      "trigger_when": "occurred during post-fix observation OR retired item re-detected"
    },
    "escalation": {
      "regression_rate_threshold": 0.4,
      "or_reactivation_count_min": 1,
      "regression_rate_denom": "matching_work_type_post_fix_sessions"
    },
    "accepted_residual": {
      "trigger_when": "regressed AND no stronger fix_type available in allowed_fix_types"
    },
    "retired": {
      "max_lifetime_confidence": 0.1,
      "min_sessions": 5
    },
    "detection_review": {
      "min_precision_records": 3,
      "max_precision": 0.5
    }
  },
  "hawthorne_correction": {
    "audit_density_window_sessions": 30,
    "warn_threshold": 0.3,
    "formula": "displayed_confidence = raw_confidence * max(0, 1 - audit_density * 0.3)"
  },
  "verdict_aging": {
    "unknown_to_tp_after_days": 30
  },
